# =============================================================================
# AdminAntizapret — sample environment file.
#
# Copy to `.env` and fill in real values:  cp .env.example .env
# NEVER commit a real `.env` (it is git-ignored). This file holds placeholders
# only — no real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Core / Flask
# -----------------------------------------------------------------------------
# REQUIRED. Flask session signing key. The app refuses to start without it.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-64-char-hex-secret

# Application / panel HTTP port (1-65535).
APP_PORT=5050

# Address gunicorn binds to. Use 127.0.0.1 behind a reverse proxy.
BIND=127.0.0.1

# Public domain of the panel (used for branding and absolute URLs). Optional.
DOMAIN=panel.example.com

# Display name shown on the login / download pages. Optional.
PANEL_BRAND_NAME=Admin Panel

# Optional: APP_ENV / FLASK_ENV influence secure-cookie defaults
# (set to "production" on a live server).
# APP_ENV=production

# -----------------------------------------------------------------------------
# TLS / HTTPS (only used when USE_HTTPS=true)
# -----------------------------------------------------------------------------
USE_HTTPS=false
# SSL_CERT=/etc/ssl/certs/adminpanel.pem
# SSL_KEY=/etc/ssl/private/adminpanel.key

# -----------------------------------------------------------------------------
# Session / cookie security
# -----------------------------------------------------------------------------
SESSION_COOKIE_SECURE=true
WTF_CSRF_SSL_STRICT=true
# SESSION_COOKIE_SAMESITE=Lax
# SESSION_COOKIE_NAME=AdminAntizapretSession
# SESSION_COOKIE_DOMAIN=
# REMEMBER_ME_DAYS=30
# PERMANENT_SESSION_LIFETIME_DAYS=7
# Idle-session bookkeeping (seconds).
ACTIVE_WEB_SESSION_TTL_SECONDS=180
ACTIVE_WEB_SESSION_TOUCH_INTERVAL_SECONDS=30

# -----------------------------------------------------------------------------
# Access / IP restriction
# -----------------------------------------------------------------------------
# Comma-separated proxy IPs that are trusted to set X-Forwarded-For.
TRUSTED_PROXY_IPS=127.0.0.1,::1
# Comma-separated allow-list of client IPs (empty = no IP allow-list).
ALLOWED_IPS=
# IP restriction strictness: strict | off | ...
IP_RESTRICTION_MODE=strict
# Set true to auto-ban scanners via iptables/ipset.
# IP_BLOCK_SCANNERS=false

# Allow unauthenticated download of generated route files (one-time links).
PUBLIC_DOWNLOAD_ENABLED=false

# -----------------------------------------------------------------------------
# Telegram authentication / Mini App
# -----------------------------------------------------------------------------
TELEGRAM_AUTH_BOT_USERNAME=YourBot
# SECRET. Bot token from @BotFather. Leave empty to disable Telegram login.
TELEGRAM_AUTH_BOT_TOKEN=
TELEGRAM_AUTH_MAX_AGE_SECONDS=300
TELEGRAM_OIDC_CLIENT_ID=
# SECRET.
TELEGRAM_OIDC_CLIENT_SECRET=
TELEGRAM_MINI_APP_SHORT_NAME=

# -----------------------------------------------------------------------------
# QR / one-time download protection (optional)
# -----------------------------------------------------------------------------
# QR_DOWNLOAD_TOKEN_TTL_SECONDS=300
# QR_DOWNLOAD_TOKEN_MAX_DOWNLOADS=1
# QR_DOWNLOAD_PIN=

# -----------------------------------------------------------------------------
# Automatic backups
# -----------------------------------------------------------------------------
APP_BACKUP_ENABLED=true
APP_BACKUP_INTERVAL_DAYS=7
APP_BACKUP_TIME=03:00
# Comma-separated components: db,env,data
APP_BACKUP_COMPONENTS=db,env,data
APP_BACKUP_TG_ENABLED=false
# Comma-separated Telegram admin IDs that receive backup files.
APP_BACKUP_TG_ADMIN_IDS=
APP_BACKUP_AZ_ENABLED=true

# -----------------------------------------------------------------------------
# Nightly idle restart
# -----------------------------------------------------------------------------
NIGHTLY_IDLE_RESTART_ENABLED=true
NIGHTLY_IDLE_RESTART_CRON=0 4 * * *

# -----------------------------------------------------------------------------
# Server monitoring / bandwidth
# -----------------------------------------------------------------------------
MONITOR_CPU_THRESHOLD=90
MONITOR_RAM_THRESHOLD=90
MONITOR_CHECK_INTERVAL_SECONDS=60
MONITOR_COOLDOWN_MINUTES=30
# Network interface reported by vnstat.
VNSTAT_IFACE=ens3
# VNSTAT_BIN=/usr/bin/vnstat

# -----------------------------------------------------------------------------
# CIDR / routing limits
# -----------------------------------------------------------------------------
OPENVPN_ROUTE_TOTAL_CIDR_LIMIT=1500
# OPENVPN_ROUTE_CIDR_LIMIT=1500
# OPENVPN_ROUTE_TOTAL_CIDR_LIMIT_MAX_IOS=900
# OPENVPN_ROUTE_MIN_PREFIXLEN=8
# OPENVPN_CERT_EXPIRY_CACHE_TTL_SECONDS=300
AZ_GAME_DISABLE_CONFIG_ROUTE_LIMIT=false
AZ_GAME_CONFIG_ROUTE_LIMIT_RISK_ACK=false
# CIDR_EXCLUDE_RU_SOURCE_URL=https://www.ipdeny.com/ipblocks/data/countries/ru.zone
# CIDR_DB_ASN_FETCH_WORKERS=4

# -----------------------------------------------------------------------------
# Gunicorn (optional tuning)
# -----------------------------------------------------------------------------
# GUNICORN_WORKERS=1
# GUNICORN_MAX_REQUESTS=1200
# GUNICORN_MAX_REQUESTS_JITTER=120
# BACKGROUND_TASK_WORKERS=2
# IO_BOUND_WORKERS=8

# -----------------------------------------------------------------------------
# Paths / service identity (usually set by install.sh; override only if needed)
# -----------------------------------------------------------------------------
# INSTALL_DIR=/opt/AdminAntizapret
# VENV_PATH=/opt/AdminAntizapret/venv
# DB_FILE=/opt/AdminAntizapret/instance/users.db
# SERVICE_NAME=admin-antizapret
# ADMIN_ANTIZAPRET_SERVICE_NAME=admin-antizapret
# ANTIZAPRET_INSTALL_DIR=/root/antizapret
# INCLUDE_DIR=/opt/AdminAntizapret/script_sh
# SCANNER_BLOCKS_FILE=
# TEMPORARY_WHITELIST_FILE=
